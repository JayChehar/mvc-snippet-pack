      "public async Task<IActionResult> EditProfile()",
      "{",
      "    int id = Convert.ToInt32(HttpContext.Session.GetInt32(\"UserId\"));",
      "    var user = await UserRepo.GetUserByUserId(id);",
      "    return View(user);",
      "}",
