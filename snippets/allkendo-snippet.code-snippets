      "[HttpPost]",
      "public async Task<IActionResult> EditProfile([FromForm] User user)",
      "{",
      "    var existingUser = await UserRepo.GetUserByUserId(Convert.ToInt32(user.UserId));",
      "",
      "    // \u00f0\u009f\u0094\u00a5 IMAGE UPDATE LOGIC",
      "    if (user.Image != null && user.Image.Length > 0)",
      "    {",
      "        var fileName = Guid.NewGuid().ToString() + Path.GetExtension(user.Image.FileName);",
      "        var folderPath = Path.Combine(Directory.GetCurrentDirectory(), \"wwwroot/profile_images\");",
      "",
      "        if (!Directory.Exists(folderPath))",
      "        {",
      "            Directory.CreateDirectory(folderPath);",
      "        }",
      "",
      "        var filePath = Path.Combine(folderPath, fileName);",
      "",
      "        // SAVE NEW IMAGE",
      "        using (var stream = new FileStream(filePath, FileMode.Create))",
      "        {",
      "            await user.Image.CopyToAsync(stream);",
      "        }",
      "",
      "        // \u00f0\u009f\u0094\u00a5 DELETE OLD IMAGE",
      "        if (!string.IsNullOrEmpty(existingUser.ImagePath))",
      "        {",
      "            var oldImagePath = Path.Combine(folderPath, existingUser.ImagePath);",
      "",
      "            if (System.IO.File.Exists(oldImagePath))",
      "            {",
      "                System.IO.File.Delete(oldImagePath);",
      "            }",
      "        }",
      "",
      "        user.ImagePath = fileName;",
      "    }",
      "    else",
      "    {",
      "        // KEEP OLD IMAGE",
      "        user.ImagePath = existingUser.ImagePath;",
      "    }",
      "",
      "    int status = await UserRepo.UpdateProfile(user);",
      "",
      "    if (status > 0)",
      "    {",
      "        return Ok(new { success = true, message = \"Updated Successfully\" });",
      "    }",
      "    else",
      "    {",
      "        return Ok(new { success = false, message = \"Error while updating profile\" });",
      "    }",
      "}",
